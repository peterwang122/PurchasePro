POLL_INTERVAL_SECONDS=5
HEADLESS=true

# 需要依次点击的分类按钮文本
CATEGORY_NAMES=推荐,黄金,白银,铂金

# 根据页面结构按需调优
CATEGORY_TAB_SELECTOR=[class*='tab'], [class*='category']
PRODUCT_CARD_SELECTOR=[class*='goods'], [class*='product'], [class*='item']
NAME_SELECTOR=[class*='name'], [class*='title']
PRICE_SELECTOR=[class*='price']
STOCK_SELECTOR=[class*='stock'], [class*='inventory']
